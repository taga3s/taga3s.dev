{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noExplicitAny": "warn"
      },
      "style": {
        "useShorthandFunctionType": "off"
      },
      "complexity": {
        "noImportantStyles": "off"
      }
    }
  },
  "files": {
    "includes": [
      "./packages/website/**",
      "./packages/assets-proxy/**",
      "./packages/mdx-processor/**",
      "!**/.wrangler",
      "!**/dist",
      "!**/node_modules"
    ]
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } }
}
