{
  "name": "taga3s-dev",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:website": "pnpm --filter=@taga3s-dev/website dev",
    "dev:assets-proxy": "pnpm --filter=@taga3s-dev/assets-proxy dev",
    "build:website": "pnpm --filter=@taga3s-dev/website build",
    "build:assets-proxy": "pnpm --filter=@taga3s-dev/assets-proxy build",
    "test:website": "pnpm --filter=@taga3s-dev/website test"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.0 <12.0.0",
      "onFail": "download"
    }
  }
}
