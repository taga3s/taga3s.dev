{
  "name": "taga3s-dev",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev:website": "pnpm --filter=@taga3s-dev/website dev",
    "dev:images-worker": "pnpm --filter=@taga3s-dev/images-worker dev",
    "build:website": "pnpm --filter=@taga3s-dev/website build",
    "build:images-worker": "pnpm --filter=@taga3s-dev/images-worker build",
    "lint": "biome lint --write ./packages/website ./packages/images-worker package.json biome.json renovate.json",
    "format": "biome format --write ./packages/website ./packages/images-worker ./packages/mdx-processor package.json biome.json renovate.json",
    "test:website": "pnpm --filter=@taga3s-dev/website test",
    "check": "biome check --write ./packages/website ./packages/images-worker ./packages/mdx-processor package.json biome.json renovate.json",
    "check:ci": "biome ci"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.0 <12.0.0",
      "onFail": "download"
    }
  }
}
