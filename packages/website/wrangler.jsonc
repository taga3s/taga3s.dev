{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "taga3s-dev-website",
  "main": "./src/index.tsx",
  "compatibility_date": "2025-02-24",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public"
  },
  "observability": {
    "logs": {
      "enabled": true
    }
  },
  "preview_urls": true,
  "routes": [
    {
      "pattern": "taga3s.dev",
      "custom_domain": true
    }
  ]
}
